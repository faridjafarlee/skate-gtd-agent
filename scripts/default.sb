;; Default Seatbelt-style sandbox profile for Skate (macOS sandbox-exec).
;; Use with: GTD_USE_SANDBOX=1 GTD_SANDBOX_PROFILE=/path/to/scripts/default.sb gtd task "..."
;; CWD and HOME are passed as -D CWD=... -D HOME=... by the runtime.
(allow default)
(allow process-exec (literal "/bin/sh"))
(allow file-read* (subpath (param "CWD")))
(allow file-write* (subpath (param "CWD")))
(allow file-read* (subpath (param "HOME")))
(allow file-write* (subpath (param "HOME")))
;; (allow network-outbound)  ; uncomment if the task needs network (e.g. web_fetch, web_search)

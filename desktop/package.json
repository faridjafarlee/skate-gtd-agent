{
  "name": "skate-desktop",
  "version": "0.2.0",
  "description": "Skate desktop app (Electron)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:mac:universal": "electron-builder --mac --universal"
  },
  "keywords": ["skate", "gtd", "electron"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.skate.desktop",
    "productName": "Skate",
    "directories": { "output": "out" },
    "files": ["main.js", "preload.js", "index.html", "renderer.js"],
    "mac": {
      "category": "public.app-category.productivity",
      "minimumSystemVersion": "12.0",
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }, { "target": "zip", "arch": ["x64", "arm64"] }],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": { "sign": false },
    "win": { "target": ["nsis"] },
    "linux": { "target": ["AppImage"] },
    "publish": null
  }
}

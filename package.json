{
  "name": "skate",
  "version": "0.2.0",
  "description": "Skate — GTD. Agent orchestration CLI",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "gtd": "dist/cli/index.js",
    "skate": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "gtd": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "ci": "npm run build && npm run lint && npm test",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "skate",
    "gtd",
    "cli",
    "orchestration",
    "multi-agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/faridjafarlee/scaling-octo-eureka.git"
  },
  "homepage": "https://github.com/faridjafarlee/scaling-octo-eureka#readme",
  "bugs": {
    "url": "https://github.com/faridjafarlee/scaling-octo-eureka/issues"
  },
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.43.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/sdk-trace-base": "^1.28.0",
    "@opentelemetry/sdk-trace-node": "^1.28.0",
    "@slack/bolt": "^4.6.0",
    "ajv": "^8.18.0",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "discord.js": "^14.25.1",
    "imapflow": "^1.2.11",
    "matrix-bot-sdk": "^0.7.1",
    "node-telegram-bot-api": "^0.67.0",
    "nodemailer": "^8.0.1",
    "openai": "^6.27.0",
    "ora": "^8.1.1",
    "uuid": "^10.0.0"
  },
  "optionalDependencies": {
    "blessed": "^0.1.81",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^22.10.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "playwright": "^1.49.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "src/**/*.ts": "eslint"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}

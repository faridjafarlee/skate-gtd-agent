# Skate - Environment Configuration (GTD)
# Copy to .env and fill in values

# Orchestration
GTD_MODE=hybrid
GTD_QUALITY_PROFILE=balanced

# LLM Providers (optional)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=   # or GOOGLE_API_KEY for Gemini

# Telegram Bot
# TELEGRAM_BOT_TOKEN=

# Slack (Socket Mode - no public URL needed)
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# Slack (HTTP mode - requires public URL)
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# PORT=3000

# WhatsApp (Cloud API - requires public HTTPS URL for webhook)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=    # Set in Meta dashboard; default: skate-verify
# WHATSAPP_WEBHOOK_PORT=3001   # Default 3001 (3000 used by Slack HTTP)

# Discord
# DISCORD_BOT_TOKEN=

# Signal (via signal-cli-rest-api - run Docker: bbernhard/signal-cli-rest-api)
# SIGNAL_BRIDGE_URL=http://localhost:8080
# SIGNAL_NUMBER=+1234567890
# SIGNAL_POLL_INTERVAL=15000   # ms between receive polls (default 15000)

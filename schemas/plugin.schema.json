{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://skate.dev/schemas/plugin.schema.json",
  "title": "Skate Plugin Manifest",
  "description": "Plugin SDK manifest for tool providers, commands, prompts, hooks, memory adapters, channel adapters",
  "type": "object",
  "required": ["id", "name", "version"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "description": "Unique plugin identifier (kebab-case)"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable plugin name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?$",
      "description": "Semver version"
    },
    "description": {
      "type": "string",
      "description": "Plugin description"
    },
    "author": {
      "type": "string",
      "description": "Plugin author"
    },
    "toolProviders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "parameters": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "enum": ["string", "number", "boolean", "array", "object"] },
                "description": { "type": "string" },
                "required": { "type": "boolean" }
              }
            }
          }
        }
      },
      "description": "Tool providers exposed by this plugin"
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "handler": { "type": "string", "description": "Path to handler module" }
        }
      },
      "description": "CLI commands added by this plugin"
    },
    "prompts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "template"],
        "properties": {
          "id": { "type": "string" },
          "template": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "description": "Reusable prompt templates"
    },
    "hooks": {
      "type": "object",
      "properties": {
        "beforeTask": { "type": "string", "description": "Path to hook module" },
        "afterTask": { "type": "string" },
        "beforeAgent": { "type": "string" },
        "afterAgent": { "type": "string" }
      },
      "description": "Lifecycle hooks"
    },
    "memoryAdapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["project", "user", "org"] },
          "config": { "type": "object" }
        }
      },
      "description": "Memory adapter extensions"
    },
    "channelAdapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "config": { "type": "object" }
        }
      },
      "description": "Channel/connector extensions"
    }
  },
  "additionalProperties": false
}
